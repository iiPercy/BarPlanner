<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.barplanner.clientapp.AggiungiController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="New Item">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
          <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Name:" />
            <TextField fx:id="txtNome" promptText="Ex. Mojito" GridPane.columnIndex="1" />
            
            <Label text="Category:" GridPane.rowIndex="1" />
            <ComboBox fx:id="comboCategoria" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Price (€):" GridPane.rowIndex="2" />
            <TextField fx:id="txtPrezzo" promptText="Es. 8.50" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="Ingredients:" GridPane.rowIndex="3" GridPane.valignment="TOP" />
            <TextArea fx:id="txtIngredienti" prefHeight="80.0" prefWidth="200.0" promptText="Add each ingredient, separate them with a comma" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
      </GridPane>
      
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="btnAnnulla" cancelButton="true" mnemonicParsing="false" onAction="#onAnnullaClick" text="Cancel" />
            <Button fx:id="btnSalva" defaultButton="true" mnemonicParsing="false" onAction="#onSalvaClick" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Add to menu" />
         </children>
      </HBox>
   </children>
</VBox>
